{
  "name": "@leoakok/poke-agents",
  "version": "0.2.0",
  "private": true,
  "description": "MCP server for Poke: Cursor + OpenCode sessions + Next dashboard",
  "type": "module",
  "workspaces": [
    "web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "npm run -w web lint",
    "test": "npm run test:smoke",
    "test:smoke": "npm run build:mcp && POKE_AGENTS_MCP_LOG=0 node --test dist/smoke/mcp-tools-smoke.test.js",
    "test:smoke:control": "npm run build:mcp && POKE_AGENTS_MCP_LOG=0 POKE_AGENTS_SMOKE_CONTROL_CLIS=1 node --test dist/smoke/control-clis-smoke.test.js",
    "test:smoke:all": "npm run build:mcp && POKE_AGENTS_MCP_LOG=0 POKE_AGENTS_SMOKE_CONTROL_CLIS=1 node --test dist/smoke/mcp-tools-smoke.test.js dist/smoke/control-clis-smoke.test.js",
    "build": "npm run build:mcp && npm run -w web build",
    "build:mcp": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "start": "node ./cli.mjs",
    "start:http": "node ./dist/mcp/run.js --http",
    "start:poke": "node ./scripts/poke-run.mjs",
    "dev": "npm run build:mcp && node ./cli.mjs",
    "dev:http": "npm run build:mcp && node ./dist/mcp/run.js --http",
    "dev:web": "npm run -w web dev",
    "mcp": "node ./dist/mcp/run.js",
    "mcp:http": "node ./dist/mcp/run.js --http"
  },
  "bin": {
    "poke-agents-mcp": "./cli.mjs"
  },
  "keywords": [
    "poke",
    "mcp",
    "cursor",
    "agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leoakok/poke-agents.git"
  },
  "bugs": {
    "url": "https://github.com/leoakok/poke-agents/issues"
  },
  "homepage": "https://github.com/leoakok/poke-agents#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "cli.mjs",
    "scripts",
    "web",
    "vendor",
    "NOTICE",
    "LICENSE",
    "README.md",
    "SKILL.md",
    "docs"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "semantic-release": "^24.2.0",
    "typescript": "^5.7.3"
  }
}
