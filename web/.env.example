# Where Next proxies /api/* (MCP JSON). Set when using `npm run dev:web` while MCP
# runs on another host/port (e.g. after `npm run start:http`).
POKE_AGENTS_MCP_ORIGIN=http://127.0.0.1:8740

# Optional legacy: direct browser → MCP (skips Next proxy). Prefer POKE_AGENTS_MCP_ORIGIN + proxy.
# NEXT_PUBLIC_POKE_AGENTS_ORIGIN=http://127.0.0.1:8740
